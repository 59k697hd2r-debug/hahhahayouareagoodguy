name: Auto Obfuscate Code
on:
  push:
    branches:
      - main  # Runs every time you push or edit code on main

jobs:
  obfuscate:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/checkout@v4 # Installs runtime environments automatically

      - name: Install Obfuscator
        run: npm install -g javascript-obfuscator

      - name: Obfuscate the Target File
        run: |
          # Replace 'myscript.js' with your actual file name
          javascript-obfuscator myscript.js --output ownersscript.lua

      - name: Commit and Push Obfuscated File
        run: |
          git config --global user.name 'github-actions[bot]'
          git config --global user.email 'github-actions[bot]@://github.com'
          git add ownersscript.lua
          git commit -m "Automated mobile obfuscation" || exit 0
          git push
